# Copy this file to .env and fill in your values

# ── Main agent LLM key (Groq — used by all agents) ────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: override model defaults ─────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# ── Chatbot widget (separate Groq key — never touches agent quota) ─────────
# Get a free key at console.groq.com (separate account or project)
# This goes in frontend/.env (Vite reads it at build time)
# VITE_CHATBOT_GROQ_KEY=your_second_groq_key_here
